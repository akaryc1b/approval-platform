# Generic REST host URL. Production hosts must use HTTPS.
APPROVAL_HOST_URL=https://ruoyi.example.com

# Must match the Host Starter approval.host tenant configuration.
APPROVAL_TENANT_ID=000000

# Must match the configured tenant key ID.
APPROVAL_KEY_ID=approval-key-2026-01

# Never commit a real secret. UTF-8 and base64:<value> are supported.
# The decoded value must contain at least 32 bytes.
APPROVAL_HOST_SECRET=replace-with-at-least-32-random-bytes

# Use generic, ruoyi5, ruoyi6, or the custom connector source configured by the host.
APPROVAL_SOURCE=ruoyi5

# Required by the auth and suite commands. Keep this out of shell history and CLI arguments.
APPROVAL_CREDENTIAL=replace-with-a-valid-sa-token
APPROVAL_CREDENTIAL_TYPE=SA_TOKEN

# Optional request timeout in milliseconds.
APPROVAL_TIMEOUT_MS=10000
