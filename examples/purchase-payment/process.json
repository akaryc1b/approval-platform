{
  "schemaVersion": "1.0",
  "definitionKey": "purchase-payment",
  "version": 1,
  "name": "Purchase payment approval",
  "startNodeId": "start",
  "nodes": [
    {
      "id": "start",
      "type": "START",
      "name": "Start",
      "next": "managerApproval"
    },
    {
      "id": "managerApproval",
      "type": "APPROVAL",
      "name": "Initiator manager approval",
      "assignee": {
        "resolver": "INITIATOR_MANAGER",
        "variable": "managerAssignee",
        "emptyPolicy": "FAIL"
      },
      "mode": "SINGLE",
      "next": "amountCondition"
    },
    {
      "id": "amountCondition",
      "type": "CONDITION",
      "name": "High-value finance review decision",
      "routes": [
        {
          "condition": {
            "field": "amount",
            "operator": "GREATER_THAN_OR_EQUAL",
            "value": 10000.00
          },
          "next": "financeReview"
        }
      ],
      "defaultNext": "financeCountersign"
    },
    {
      "id": "financeReview",
      "type": "APPROVAL",
      "name": "High-value finance approval",
      "assignee": {
        "resolver": "VARIABLE_USER",
        "variable": "financeReviewer",
        "emptyPolicy": "FAIL"
      },
      "mode": "SINGLE",
      "next": "financeCountersign"
    },
    {
      "id": "financeCountersign",
      "type": "APPROVAL",
      "name": "Parallel finance countersign",
      "assignee": {
        "resolver": "VARIABLE_USER_LIST",
        "variable": "financeApprovers",
        "emptyPolicy": "FAIL"
      },
      "mode": "ALL",
      "next": "end"
    },
    {
      "id": "end",
      "type": "END",
      "name": "Completed"
    }
  ]
}
