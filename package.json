{
  "name": "approval-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Production-oriented approval platform built on Flowable",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/akaryc1b/approval-platform.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": "^22.18.0 || ^24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build:packages": "pnpm --filter './packages/**' build",
    "check": "pnpm -r --if-present check",
    "clean": "pnpm -r --if-present clean",
    "web:bootstrap": "node scripts/upstream/bootstrap-vben.mjs",
    "web:clean": "node scripts/upstream/bootstrap-vben.mjs --clean",
    "web:install": "pnpm web:bootstrap && pnpm --dir .upstream/vben install --frozen-lockfile",
    "web:dev": "pnpm web:bootstrap && pnpm --dir .upstream/vben dev:ele",
    "web:typecheck": "pnpm web:bootstrap && pnpm --dir .upstream/vben --filter @vben/web-ele typecheck",
    "web:build": "pnpm web:bootstrap && pnpm --dir .upstream/vben build:ele",
    "mobile:bootstrap": "node scripts/upstream/bootstrap-unibest.mjs",
    "mobile:clean": "node scripts/upstream/bootstrap-unibest.mjs --clean",
    "mobile:install": "pnpm mobile:bootstrap && pnpm -C .upstream/unibest install --no-frozen-lockfile",
    "mobile:dev:h5": "pnpm mobile:bootstrap && pnpm -C .upstream/unibest dev:h5",
    "mobile:typecheck": "pnpm mobile:bootstrap && pnpm -C .upstream/unibest type-check",
    "mobile:build:h5": "pnpm mobile:bootstrap && pnpm -C .upstream/unibest build:h5",
    "mobile:build:weixin": "pnpm mobile:bootstrap && pnpm -C .upstream/unibest build:mp-weixin"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
